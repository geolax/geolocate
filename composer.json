{
    "name": "geolax/geolocate",
    "description": "Extensible geolocation lookup for Laravel — driver-based, addon-ready",
    "keywords": [
        "laravel",
        "geolocate",
        "geolocation",
        "ip-lookup"
    ],
    "homepage": "https://github.com/geolax/geolocate",
    "license": "MIT",
    "authors": [
        {
            "name": "Bishwajit Adhikary",
            "email": "bishwajitcadhikary@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^11.0||^12.0||^13.0",
        "illuminate/support": "^11.0||^12.0||^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Geolax\\Geolocate\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Geolax\\Geolocate\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Geolax\\Geolocate\\GeolocateServiceProvider"
            ],
            "aliases": {
                "Geolocate": "Geolax\\Geolocate\\Facades\\Geolocate"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
